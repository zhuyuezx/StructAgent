{
  "domain": "drawio",
  "interfaces": [
    "drawio",
    "imovie"
  ],
  "paths": {
    "screenshots_dir": "screenshots",
    "test_output_dir": "test_output",
    "state_dir": "state",
    "scene_graph_dir": "scene_graph"
  },
  "calibration": {
    "canvas_nodes": [],
    "canvas_edges": [],
    "empty_canvas_point": [
      600,
      400
    ]
  },
  "llm": {
    "model": "qwen3.5:35b",
    "max_steps": 10
  },
  "models": {
    "planner": {
      "provider": "openai_compatible",
      "model": "Qwen3.5-4B",
      "base_url": "http://127.0.0.1:8001/v1",
      "timeout": 120,
      "max_tokens": 32768,
      "temperature": 0
    },
    "executor": {
      "provider": "openai_compatible",
      "model": "Qwen3.5-4B",
      "base_url": "http://127.0.0.1:8001/v1",
      "timeout": 120,
      "max_tokens": 1024,
      "temperature": 0
    },
    "critic": {
      "provider": "openai_compatible",
      "model": "Qwen3.5-4B",
      "base_url": "http://127.0.0.1:8001/v1",
      "timeout": 120,
      "max_tokens": 512,
      "temperature": 0
    },
    "explorer": {
      "provider": "openai_compatible",
      "model": "Qwen3.5-4B",
      "base_url": "http://127.0.0.1:8001/v1",
      "timeout": 120,
      "max_tokens": 64,
      "temperature": 0
    }
  },
  "target": {
    "backend": "chrome_cdp",
    "debug_port": 9222,
    "url_match": [
      "app.diagrams.net",
      "draw.io",
      "drawio"
    ],
    "screenshot_mode": "tab",
    "fallback": "none"
  },
  "executor": {
    "failsafe": true,
    "pause": 0.15,
    "drag_duration": 0.5,
    "type_interval": 0.03,
    "step_cooldown": 0.5,
    "countdown_seconds": 5
  },
  "explorer": {
    "model": "qwen3-vl:4b",
    "screen_scale": 2,
    "sidebar_region": [
      0,
      480,
      760,
      1120
    ],
    "icon_size_range": [
      20,
      70
    ],
    "nms_distance": 20,
    "label_timeout": 30,
    "label_max_retries": 2
  },
  "critic": {
    "model": "qwen3-vl:4b",
    "timeout": 60
  }
}
