{
  "domain": "drawio",
  "interfaces": [
    "drawio",
    "imovie"
  ],
  "paths": {
    "screenshots_dir": "screenshots",
    "test_output_dir": "test_output",
    "state_dir": "state",
    "scene_graph_dir": "scene_graph"
  },
  "calibration": {
    "canvas_nodes": [],
    "canvas_edges": [],
