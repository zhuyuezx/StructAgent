{
  "name": "move_and_deselect",
  "description": "Drag a node to a position, then deselect.",
  "params": [
    "node_ref",
    "target_x",
    "target_y"
  ],
  "needs_ui_graph": true,
  "steps": [
    {
      "tool": "drag_node",
      "params": {
        "node_ref": "$node_ref",
        "target_x": "$target_x",
        "target_y": "$target_y"
      }
    },
    {
      "tool": "click_empty_canvas",
      "params": {}
    }
  ]
}